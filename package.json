{
  "name": "@cheen/monorepo",
  "version": "1.0.0",
  "description": "Monorepo for personal homepage and tech summary",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev:homepage": "pnpm --filter @cheen/personal-homepage dev",
    "dev:tech": "pnpm --filter @cheen/tech-summary dev",
    "build:homepage": "pnpm --filter @cheen/personal-homepage build",
    "build:tech": "pnpm --filter @cheen/tech-summary build",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r test:unit",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^1.8.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
