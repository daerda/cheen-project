    }
  },
  "scripts": {
    "lint": "echo 'No linting for ui package'"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.3.0",
    "vue": "^3.4.0"
  }
}
